# Binaries (root-only anchors; never match cmd/plaud/ source dir)
/plaud
/plaud.exe
/dist/
/bin/

# Test artifacts
coverage.out
coverage.html
*.test
*.prof

# Go workspace
go.work
go.work.sum

# Local-only files
*.local.*
.env
.env.local

# Network captures (contain tokens, emails, cookies — never commit)
*.har
*.har.gz

# Per-spec raw resources (real recordings, exported transcripts/summaries with PII)
specs/*/resources/

# Editor
.vscode/
.idea/
*.swp
*~
.DS_Store

# Local Claude state, except shared repo skills
.claude/*
!.claude/skills/
